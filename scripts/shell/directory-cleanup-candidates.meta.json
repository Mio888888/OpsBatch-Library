{
  "name": "目录清理候选报告",
  "url": "https://raw.githubusercontent.com/Mio888888/OpsBatch-Library/main/scripts/shell/directory-cleanup-candidates.sh",
  "language": "shell",
  "category": "maintenance",
  "tags": [
    "maintenance",
    "disk",
    "cleanup-candidates",
    "stale-files"
  ],
  "risk": "medium",
  "description": "只读统计目录占用、陈旧文件候选和较大的直接子项，便于人工评估清理范围。不会删除文件；输出可能包含文件路径。",
  "parameters": [
    {
      "name": "target_dir",
      "description": "需要检查的目录",
      "required": false,
      "default": "."
    },
    {
      "name": "older_than_days",
      "description": "筛选修改时间早于该天数的文件",
      "required": false,
      "default": "30"
    },
    {
      "name": "limit",
      "description": "最多展示的候选数量",
      "required": false,
      "default": "50"
    }
  ],
  "platform": [
    "linux",
    "macos"
  ]
}
