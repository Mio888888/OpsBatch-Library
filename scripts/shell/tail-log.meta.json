{
  "name": "查看日志尾部",
  "url": "https://raw.githubusercontent.com/Mio888888/OpsBatch-Library/main/scripts/shell/tail-log.sh",
  "language": "shell",
  "category": "log",
  "tags": [
    "log",
    "troubleshooting"
  ],
  "risk": "low",
  "description": "查看指定日志文件最后若干行。默认读取 /var/log/system.log 的最后 100 行。",
  "parameters": [
    {
      "name": "log_file",
      "description": "日志文件路径",
      "required": false,
      "default": "/var/log/system.log"
    },
    {
      "name": "lines",
      "description": "输出行数",
      "required": false,
      "default": "100"
    }
  ],
  "platform": [
    "linux",
    "macos"
  ]
}
