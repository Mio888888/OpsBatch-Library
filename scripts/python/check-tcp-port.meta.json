{
  "name": "检查 TCP 端口连通性",
  "language": "python",
  "category": "network",
  "tags": [
    "network",
    "troubleshooting",
    "port"
  ],
  "risk": "low",
  "description": "尝试连接指定主机和 TCP 端口，不发送业务数据，用于基础连通性排查。",
  "parameters": [
    {
      "name": "host",
      "description": "目标主机",
      "required": false,
      "default": "127.0.0.1"
    },
    {
      "name": "port",
      "description": "目标 TCP 端口",
      "required": false,
      "default": "80"
    },
    {
      "name": "timeout",
      "description": "连接超时时间（秒）",
      "required": false,
      "default": "3"
    }
  ],
  "platform": [
    "linux",
    "macos",
    "windows"
  ]
}
