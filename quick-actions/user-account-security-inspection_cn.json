{
  "name": "账号与权限安全巡检",
  "description": "串联本地账号、组成员、sudo 权限、登录会话、密码策略、SSH 授权密钥、异常 UID/GID、家目录和认证日志等只读检查，适合账号与权限安全基线巡检。",
  "url": "https://raw.githubusercontent.com/Mio888888/OpsBatch-Library/main/quick-actions/user-account-security-inspection_cn.json",
  "category": "巡检",
  "risk": "medium",
  "tags": [
    "用户",
    "账号",
    "安全",
    "巡检"
  ],
  "platform": [
    "linux",
    "macos"
  ],
  "steps": [
    {
      "name": "查看本地用户账户摘要",
      "type": "command",
      "ref": "commands/security/local-user-summary_cn.yml",
      "url": "https://raw.githubusercontent.com/Mio888888/OpsBatch-Library/main/commands/security/local-user-summary_cn.yml",
      "continueOnError": true
    },
    {
      "name": "查看用户组和成员关系",
      "type": "command",
      "ref": "commands/security/group-membership-summary_cn.yml",
      "url": "https://raw.githubusercontent.com/Mio888888/OpsBatch-Library/main/commands/security/group-membership-summary_cn.yml",
      "continueOnError": true
    },
    {
      "name": "查看 sudoers 权限摘要",
      "type": "command",
      "ref": "commands/security/sudoers-summary_cn.yml",
      "url": "https://raw.githubusercontent.com/Mio888888/OpsBatch-Library/main/commands/security/sudoers-summary_cn.yml",
      "continueOnError": true
    },
    {
      "name": "查看用户登录会话详情",
      "type": "command",
      "ref": "commands/security/login-session-detail_cn.yml",
      "url": "https://raw.githubusercontent.com/Mio888888/OpsBatch-Library/main/commands/security/login-session-detail_cn.yml",
      "continueOnError": true
    },
    {
      "name": "查看密码与过期策略",
      "type": "command",
      "ref": "commands/security/password-policy-aging_cn.yml",
      "url": "https://raw.githubusercontent.com/Mio888888/OpsBatch-Library/main/commands/security/password-policy-aging_cn.yml",
      "continueOnError": true
    },
    {
      "name": "检查 SSH 授权密钥",
      "type": "command",
      "ref": "commands/security/ssh-authorized-keys-audit_cn.yml",
      "url": "https://raw.githubusercontent.com/Mio888888/OpsBatch-Library/main/commands/security/ssh-authorized-keys-audit_cn.yml",
      "continueOnError": true
    },
    {
      "name": "查找异常 UID/GID 账号",
      "type": "command",
      "ref": "commands/security/uid-gid-anomalies_cn.yml",
      "url": "https://raw.githubusercontent.com/Mio888888/OpsBatch-Library/main/commands/security/uid-gid-anomalies_cn.yml",
      "continueOnError": true
    },
    {
      "name": "检查用户家目录状态",
      "type": "command",
      "ref": "commands/security/home-directory-audit_cn.yml",
      "url": "https://raw.githubusercontent.com/Mio888888/OpsBatch-Library/main/commands/security/home-directory-audit_cn.yml",
      "continueOnError": true
    },
    {
      "name": "查看 SSH 登录日志",
      "type": "command",
      "ref": "commands/security/ssh-login-logs_cn.yml",
      "url": "https://raw.githubusercontent.com/Mio888888/OpsBatch-Library/main/commands/security/ssh-login-logs_cn.yml",
      "continueOnError": true
    },
    {
      "name": "查看认证失败日志",
      "type": "command",
      "ref": "commands/security/auth-failure-logs_cn.yml",
      "url": "https://raw.githubusercontent.com/Mio888888/OpsBatch-Library/main/commands/security/auth-failure-logs_cn.yml",
      "continueOnError": true
    }
  ]
}
