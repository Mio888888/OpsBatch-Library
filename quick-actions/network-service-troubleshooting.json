{
  "name": "网络与服务排障",
  "description": "串联基础连通性、DNS、路由、接口、端口监听、活动连接、网卡错误、吞吐采样和服务端口探测，辅助快速定位常见网络/服务问题。",
  "category": "troubleshooting",
  "risk": "medium",
  "tags": [
    "network",
    "service",
    "troubleshooting"
  ],
  "platform": [
    "linux",
    "macos"
  ],
  "steps": [
    {
      "name": "查看网络接口与 IP 地址",
      "type": "command",
      "ref": "commands/network/network-interface-summary.yml",
      "continueOnError": true
    },
    {
      "name": "查看路由表与默认网关",
      "type": "command",
      "ref": "commands/network/network-route-table.yml",
      "continueOnError": true
    },
    {
      "name": "Ping 默认网关",
      "type": "command",
      "ref": "commands/network/ping-gateway.yml",
      "continueOnError": true
    },
    {
      "name": "查看 DNS 配置",
      "type": "command",
      "ref": "commands/network/dns-config-summary.yml",
      "continueOnError": true
    },
    {
      "name": "检查 DNS 解析",
      "type": "command",
      "ref": "commands/network/dns-resolution-check.yml",
      "continueOnError": true
    },
    {
      "name": "检查目标网络连通性",
      "type": "command",
      "ref": "commands/network/network-connectivity-check.yml",
      "continueOnError": true
    },
    {
      "name": "查看本地监听端口",
      "type": "command",
      "ref": "commands/network/list-listening-ports.yml",
      "continueOnError": true
    },
    {
      "name": "查看活动网络连接摘要",
      "type": "command",
      "ref": "commands/network/active-connections-summary.yml",
      "continueOnError": true
    },
    {
      "name": "查看远端连接排行",
      "type": "command",
      "ref": "commands/network/top-remote-connections.yml",
      "continueOnError": true
    },
    {
      "name": "查看网络连接对应进程",
      "type": "command",
      "ref": "commands/network/network-socket-processes.yml",
      "continueOnError": true
    },
    {
      "name": "查看网卡错误与丢包统计",
      "type": "command",
      "ref": "commands/network/network-interface-errors.yml",
      "continueOnError": true
    },
    {
      "name": "采样网络接口吞吐",
      "type": "command",
      "ref": "commands/network/network-throughput-sampling.yml",
      "continueOnError": true
    },
    {
      "name": "查看 ARP 与邻居表",
      "type": "command",
      "ref": "commands/network/arp-neighbor-table.yml",
      "continueOnError": true
    },
    {
      "name": "检查本机 HTTP 端口",
      "type": "script",
      "ref": "scripts/python/check-tcp-port.py",
      "args": [
        "127.0.0.1",
        "80"
      ],
      "continueOnError": true
    },
    {
      "name": "查找高 CPU 进程",
      "type": "command",
      "ref": "commands/cpu/top-cpu-processes.yml",
      "continueOnError": true
    }
  ]
}
