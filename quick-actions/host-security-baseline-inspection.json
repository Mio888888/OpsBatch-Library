{
  "name": "主机安全基线巡检",
  "description": "串联主机基线、账号权限、认证日志、网络暴露面、防火墙、可疑进程/连接、文件权限/完整性、证书密钥、计划任务和内核安全参数等只读检查，适合安全维度快速巡检。",
  "category": "inspection",
  "risk": "medium",
  "tags": [
    "security",
    "baseline",
    "inspection",
    "host"
  ],
  "platform": [
    "linux",
    "macos"
  ],
  "steps": [
    {
      "name": "查看主机安全基线摘要",
      "type": "command",
      "ref": "commands/security/host-security-baseline-summary.yml",
      "continueOnError": true
    },
    {
      "name": "查看内核安全参数摘要",
      "type": "command",
      "ref": "commands/security/kernel-hardening-summary.yml",
      "continueOnError": true
    },
    {
      "name": "查看本地用户账户摘要",
      "type": "command",
      "ref": "commands/security/local-user-summary.yml",
      "continueOnError": true
    },
    {
      "name": "查找异常 UID/GID 账号",
      "type": "command",
      "ref": "commands/security/uid-gid-anomalies.yml",
      "continueOnError": true
    },
    {
      "name": "查看 sudoers 权限摘要",
      "type": "command",
      "ref": "commands/security/sudoers-summary.yml",
      "continueOnError": true
    },
    {
      "name": "检查 SSH 授权密钥",
      "type": "command",
      "ref": "commands/security/ssh-authorized-keys-audit.yml",
      "continueOnError": true
    },
    {
      "name": "查看 SSH 服务安全配置摘要",
      "type": "command",
      "ref": "commands/security/ssh-server-security-summary.yml",
      "continueOnError": true
    },
    {
      "name": "查看网络暴露面摘要",
      "type": "command",
      "ref": "commands/security/network-exposure-summary.yml",
      "continueOnError": true
    },
    {
      "name": "查看防火墙状态摘要",
      "type": "command",
      "ref": "commands/security/firewall-status-summary.yml",
      "continueOnError": true
    },
    {
      "name": "查看可疑进程线索",
      "type": "command",
      "ref": "commands/security/suspicious-process-indicators.yml",
      "continueOnError": true
    },
    {
      "name": "查看可疑网络连接线索",
      "type": "command",
      "ref": "commands/security/suspicious-network-connections.yml",
      "continueOnError": true
    },
    {
      "name": "查看安全事件日志时间线",
      "type": "command",
      "ref": "commands/security/security-log-timeline.yml",
      "continueOnError": true
    },
    {
      "name": "查看文件权限风险摘要",
      "type": "command",
      "ref": "commands/security/file-permission-risk-summary.yml",
      "continueOnError": true
    },
    {
      "name": "生成关键文件完整性基线摘要",
      "type": "command",
      "ref": "commands/security/file-integrity-baseline.yml",
      "continueOnError": true
    },
    {
      "name": "查看证书过期摘要",
      "type": "command",
      "ref": "commands/security/certificate-expiry-summary.yml",
      "continueOnError": true
    },
    {
      "name": "检查私钥文件权限线索",
      "type": "command",
      "ref": "commands/security/private-key-permission-audit.yml",
      "continueOnError": true
    },
    {
      "name": "检查计划任务和启动项",
      "type": "command",
      "ref": "commands/security/scheduled-startup-items-audit.yml",
      "continueOnError": true
    }
  ]
}
